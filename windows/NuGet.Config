<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Keep restore deterministic and avoid hangs on unreachable feeds. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Fallback for networks that block the v3 service index -->
    <add key="nuget.org-v2" value="https://www.nuget.org/api/v2/" />
  </packageSources>
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
  <config>
    <add key="ignoreFailedSources" value="true" />
  </config>
</configuration>
