{
  "name": "EnviroApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "postinstall": "powershell -ExecutionPolicy Bypass -File scripts/patch-rnw-x64.ps1",
    "ios": "react-native run-ios",
    "web": "webpack serve --config webpack.config.js --mode development",
    "web:build": "webpack --config webpack.config.js --mode production",
    "windows": "react-native run-windows",
    "windows:release": "react-native run-windows --release",
    "windows:x64": "react-native run-windows --arch x64",
    "windows:init": "react-native-windows-init --overwrite",
    "macos": "react-native run-macos",
    "macos:release": "react-native run-macos --configuration Release",
    "macos:init": "react-native-macos-init --overwrite",
    "lint": "eslint .",
    "start": "react-native start",
    "start:windows": "react-native start --platforms windows",
    "start:macos": "react-native start --platforms macos",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-native": "0.82.0",
    "react-native-document-picker": "^9.3.1",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.2",
    "react-native-windows": "0.82.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^15.0.0",
    "@react-native-community/cli-platform-android": "^15.0.0",
    "@react-native-community/cli-platform-ios": "^15.0.0",
    "@react-native/babel-preset": "0.82.0",
    "@react-native/eslint-config": "0.82.0",
    "@react-native/metro-config": "0.82.0",
    "@react-native/typescript-config": "0.82.0",
    "@types/jest": "^29.5.13",
    "@types/react": "19.1.1",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.0.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "EnviroApp",
      "namespace": "EnviroApp",
      "template": "cpp-app"
    }
  }
}
